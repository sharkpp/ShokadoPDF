{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ShokadoPDF",
  "version": "0.1.0",
  "identifier": "net.sharkpp.shokadopdf",
  "build": {
    "frontendDist": "../core/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx cross-env SIMPLE_MODE=true VITE_BRAND_NAME=ShokadoPDF npm --prefix core run dev -- --port 1420 --strictPort",
    "beforeBuildCommand": "npx cross-env SIMPLE_MODE=true VITE_BRAND_NAME=ShokadoPDF npm --prefix core run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
