# Dev-only: route TSA/certificate requests through the built-in Vite CORS proxy
VITE_CORS_PROXY_URL=/cors-proxy

# ShokadoPDF — use locally-bundled AGPL WASM modules in dev too (offline).
# Mirrors .env.production so `tauri dev` exercises the same local paths.
VITE_WASM_PYMUPDF_URL=/wasm/pymupdf/
VITE_WASM_GS_URL=/wasm/gs/
VITE_WASM_CPDF_URL=/wasm/cpdf/
