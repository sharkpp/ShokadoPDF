# ShokadoPDF — offline desktop build
# Point the AGPL WASM modules to locally-bundled assets copied by
# viteStaticCopy (see core/vite.config.ts -> staticCopyTargets),
# instead of the jsdelivr CDN. Enables fully offline PDF processing.
VITE_WASM_PYMUPDF_URL=/wasm/pymupdf/
VITE_WASM_GS_URL=/wasm/gs/
VITE_WASM_CPDF_URL=/wasm/cpdf/
